---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<footer class:list={['footer', className]}>
  <nav aria-label="Legal">
    <a href="/terms">Terms of Service</a>
    <span class="separator" aria-hidden="true">|</span>
    <a href="/privacy">Privacy Policy</a>
  </nav>
</footer>

<style>
  .footer {
    padding: 1.5rem 1rem;
    text-align: center;
    border-top: 1px solid rgba(156, 126, 212, 0.15);
    background: #f3f0f9;
  }

  .footer nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer a {
    color: #5a5568;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .footer a:hover {
    color: #9c7ed4;
  }

  .separator {
    color: #c4b8d4;
    font-size: 0.75rem;
  }
</style>
