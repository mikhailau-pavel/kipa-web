---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kipa"
  description="Save, organize, and manage your links. Kipa is a link organizer and saver app for iOS."
  openGraph={{ image: '/icon.png' }}
>
  <main class="landing">
    <section class="hero">
      <img src="/icon.png" alt="Kipa" class="hero-icon" width="120" height="120" />
      <h1 class="hero-title">Kipa</h1>
      <p class="hero-tagline">Save, organize, and manage your links</p>
      <p class="hero-description">
        A link organizer and saver that helps you collect web links and notes in one place. Organize with categories, sync across devices, and never lose a link again.
      </p>
      <div class="cta-group">
        <a href="https://apps.apple.com/app/kipa" class="cta cta-primary" target="_blank" rel="noopener noreferrer">
          Download on the App Store
        </a>
      </div>
    </section>

    <section class="screenshots" aria-label="App screenshots">
      <h2 class="screenshots-title">See Kipa in action</h2>
      <div class="screenshots-grid">
        <img src="/screenshots/1.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
        <img src="/screenshots/2.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
        <img src="/screenshots/3.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
        <img src="/screenshots/4.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
        <img src="/screenshots/5.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
        <img src="/screenshots/6.png" alt="Kipa app screenshot" width="390" height="844" loading="lazy" />
      </div>
    </section>

    <section class="features">
      <div class="feature">
        <h2>Save links</h2>
        <p>Capture any link with a tap. Save from Safari, share sheets, or paste directly.</p>
      </div>
      <div class="feature">
        <h2>Organize</h2>
        <p>Create categories and collections. Keep your links tidy and easy to find.</p>
      </div>
      <div class="feature">
        <h2>Sync</h2>
        <p>Your links sync across your devices. Access them wherever you go.</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .landing {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 1.5rem 4rem;
    background: linear-gradient(180deg, #f5f1fa 0%, #f8f6fc 40%, #f8f6fc 100%);
  }

  .hero {
    text-align: center;
    max-width: 560px;
    margin-bottom: 4rem;
  }

  .hero-icon {
    display: block;
    margin: 0 auto 1.5rem;
    border-radius: 24px;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: #9c7ed4;
    font-weight: 500;
    margin: 0 0 1rem;
  }

  .hero-description {
    font-size: 1.125rem;
    color: #4b5563;
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .cta-group {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .cta-primary {
    background: #9c7ed4;
    color: white;
    box-shadow: 0 2px 8px rgba(156, 126, 212, 0.35);
  }

  .cta-primary:hover {
    background: #8b6bc4;
    box-shadow: 0 4px 12px rgba(156, 126, 212, 0.4);
  }

  .screenshots {
    width: 100%;
    max-width: 900px;
    margin-bottom: 4rem;
  }

  .screenshots-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    justify-items: center;
  }

  .screenshots-grid img {
    width: 100%;
    max-width: 200px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 4px 20px rgba(156, 126, 212, 0.15);
    border: 1px solid rgba(156, 126, 212, 0.1);
  }

  .features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 720px;
    width: 100%;
  }

  .feature {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 12px;
    border: 1px solid rgba(156, 126, 212, 0.2);
    box-shadow: 0 1px 3px rgba(156, 126, 212, 0.06);
  }

  .feature h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1f2937;
    margin: 0 0 0.5rem;
  }

  .feature p {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 640px) {
    .screenshots-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .screenshots-grid img {
      max-width: 220px;
    }

    .features {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
